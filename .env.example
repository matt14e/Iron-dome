# --- HubSpot ---
# Private App access token (Settings -> Integrations -> Private Apps -> Auth tab)
HUBSPOT_TOKEN=pat-na2-xxxxxxxx

# Optional: enables webhook signature verification. Leave VERIFY_WEBHOOKS=false until you
# confirm the signing secret for your private app, then set the secret and flip to true.
VERIFY_WEBHOOKS=false
HUBSPOT_CLIENT_SECRET=

# --- Database (Railway Postgres auto-injects DATABASE_URL) ---
DATABASE_URL=postgres://user:pass@host:5432/railway

# --- Server ---
PORT=3000
# Simple shared password to protect the UI (set to anything; required to load the dashboard).
UI_PASSWORD=change-me

# --- Team names in HubSpot (exact, case-insensitive match) ---
TEAM_CORGI_CORP=Corgi Corp
TEAM_CORGI_TECH=Corgi Tech
